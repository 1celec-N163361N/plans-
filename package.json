{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "build:libs": "tsc -b lib/db lib/api-zod lib/api-client-react",
    "build:api": "npm run build --workspace=@workspace/api-server",
    "build:web": "npm run build --workspace=@workspace/khtat-sairak",
    "build:apps": "npm run build:api && npm run build:web",
    "build": "npm run build:libs && npm run build:apps",
    "typecheck:libs": "tsc -b lib/db lib/api-zod lib/api-client-react"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}